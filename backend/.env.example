# ── Database ──────────────────────────────────────────────────────────────────
# Prisma Postgres cloud URL (from Prisma console / create-db), or local Docker below
DATABASE_URL="postgres://..."
# Commented ones were for local Docker-based Postgres
# DATABASE_URL=postgresql://speeky:pass1234@localhost:5432/speeky_db?schema=public

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development                    # development | production
CLIENT_ORIGIN=http://localhost:5173     # Frontend URL (CORS + password reset link base)

# POSTGRES_USER=speeky
# POSTGRES_PASSWORD=pass1234
# POSTGRES_DB=speeky_db

# ── JWT secrets (generate with: python -c "import secrets; print(secrets.token_hex(64))")
JWT_ACCESS_SECRET=<64-char hex>
JWT_REFRESH_SECRET=<64-char hex>
# JWT_RESET_SECRET=<64-char hex>       # Optional; falls back to JWT_ACCESS_SECRET

# ── Token TTLs ────────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL=30          # minutes
REFRESH_TOKEN_TTL_DAYS=7     # days
RESET_TOKEN_TTL_MINUTES=15   # minutes
OTP_TTL_MINUTES=10           # minutes — signup email verification code

# ── SMTP (required — Brevo SMTP relay) ─────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-brevo-smtp-key
# SMTP_FROM="Speeky AI <no-reply@speeky.ai>"
SMTP_FROM="Mazik-Global Pakistan <workmazik@gmail.com>"

# ── LLM (Groq) — powers Workplace English Coach + AI Conversation Practice ──────
# Without GROQ_API_KEY these features fall back to offline heuristics.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── TTS (Piper) — powers AI Conversation Practice's TTS playback ────────────────
# Optional. Needs the voice model file present at data/tts/ — see data/tts/README.md.
# Without it, /api/conversation/tts returns 503 and the client falls back to native TTS.
# TTS_VOICE_MODEL=en_US-lessac-medium.onnx

# ── LiveKit (voice rooms) — powers AI Conversation Practice's voice mode ────────
# Optional. Needs a LiveKit Cloud/self-hosted project's URL + key pair.
# Without it, /api/conversation/sessions/{id}/voice-token returns 503.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Shared secret the voice_agent/ worker presents (X-Internal-Secret header) when
# posting transcribed turns back — this is a trusted internal caller, not a user.
INTERNAL_AGENT_SECRET=

# Where the voice_agent/ worker (see docker-compose.yml) reaches this API. Only needed
# when running the worker via `docker compose up` — defaults to the host machine.
# BACKEND_URL=http://host.docker.internal:8000

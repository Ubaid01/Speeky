generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = "5"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AssessmentStatus {
  UNASSESSED
  IN_PROGRESS
  COMPLETED
  PLATEAUED
}

enum LearningLevel {
  BEGINNER
  ELEMENTARY
  INTERMEDIATE
  UPPER_INTERMEDIATE
  ADVANCED
  PROFICIENT
}

enum PromptKind {
  SKIP_ASSESSMENT
  REASSESSMENT
}

// Workplace English Coach scenarios
// Just like in lib/prompts.WORKPLACE_SCENARIOS.
enum CoachingScenario {
  EMAIL_WRITING          // (text)
  CLIENT_COMMUNICATION   // (audio roleplay)
  MEETING_COMMUNICATION  // (audio roleplay)
  PRESENTATION_PREP      // (audio)
  GENERAL_WORKPLACE      // (text or audio)
}

enum CoachingInputMode {
  TEXT
  AUDIO
}

enum CoachingStatus {
  IN_PROGRESS
  COMPLETED
  ENDED_EARLY   // e.g. WEC-US-10 E-01 de-escalation cut-off
}

// Accent Assessment (US-93). REJECTED_* means the reading wasn't scored at all — see
// lib/recording_engine.RejectionReason for the reason-code vocabulary these mirror.
enum AccentAssessmentStatus {
  COMPLETED
  REJECTED_NO_SPEECH
  REJECTED_TOO_QUIET
  REJECTED_TOO_NOISY
  REJECTED_INCOMPLETE
  REJECTED_MULTIPLE_VOICES
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String
  avatarUrl            String                @default("user.webp")
  role                 Role                  @default(USER)
  assessmentStatus     AssessmentStatus      @default(UNASSESSED)
  learningLevel        LearningLevel?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  passwordResetTokens  PasswordResetToken[]
  refreshTokens        RefreshToken[]
  baselineAssessments  BaselineAssessment[]
  reassessmentRequests ReassessmentRequest[]
  promptLogs           PromptLog[]
  coachingSessions     CoachingSession[]
  scenarioSessions     ScenarioSession[]
  accentAssessments    AccentAssessment[]
  pronunciationAttempts PronunciationAttempt[]
  accentAssessments    AccentAssessment[]
  accentProfiles       AccentProfile[]

  @@map("users")
}

// Scenario-Based Learning session --> String (not an enum, unlike CoachingScenario) because admins can add custom
// scenarios at runtime without a migration — built-ins live in
// lib/prompts.SBL_SCENARIOS, custom ones in the CustomScenario table, keyed
// "custom:<id>". targetVocab is snapshotted at session start so a later admin
// edit to a custom scenario doesn't retroactively change grading.
model ScenarioSession {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenarioKey      String
  status           String    @default("in_progress") // in_progress | completed | ended_early
  turns            Json      @default("[]")          // [{role, content}]
  targetVocab      String[]
  vocabUsed        String[]  @default([])

  politenessScore  Float?
  vocabularyScore  Float?
  confidenceScore  Float?
  metGoal          Boolean?  // only meaningful for goal_type "negotiation" scenarios

  flags            Json      @default("[]")
  summary          String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([userId])
  @@map("scenario_sessions")
}

// Admin-authored Scenario-Based Learning scenarios. Merged with the
// built-in lib/prompts.SBL_SCENARIOS at read time. Publishing is just a DB write —
// no app update needed, per the story's acceptance criteria.
model CustomScenario {
  id             String   @id @default(cuid())
  title          String   @unique
  category       String
  persona        String
  systemPrompt   String
  openingLine    String?
  targetVocab    String[]
  goalType       String   @default("roleplay") // roleplay | negotiation
  corporateTone  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("custom_scenarios")
}

// Workplace English Coach session (WEC-US-08 .. WEC-US-12).
// A row with completedAt=None is in progress (roleplay scenarios may span
// several turns held in `turns`). Scores are confidence-first: professionalTone is the
// headline metric, independent of grammar.
model CoachingSession {
  id                 String            @id @default(cuid())
  userId             String
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenario           CoachingScenario
  inputMode          CoachingInputMode
  status             CoachingStatus    @default(IN_PROGRESS)
  promptText         String                                     // scenario brief shown to user
  submission         String?                                    // final text / transcript graded
  turns              Json              @default("[]")            // roleplay dialogue [{role,content}]
  audioFeatures      Json?                                      // AUDIO pipeline signal snapshot

  // Scores (0-100). pronunciationScore stays null for the TEXT pipeline.
  professionalTone   Float?
  clarityScore       Float?
  effectivenessScore Float?
  fluencyScore       Float?
  vocabularyScore    Float?
  pronunciationScore Float?
  confidenceScore    Float?

  feedback           Json?                                      // grader summary + polished version
  flags              Json              @default("[]")           // exception-handling flags raised
  metObjective       Boolean?
  createdAt          DateTime          @default(now())
  completedAt        DateTime?

  @@index([userId])
  @@map("coaching_sessions")
}

model BaselineAssessment {
  id                 String         @id @default(cuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionIds        String[]
  currentIndex       Int            @default(0)
  responses          Json           @default("[]")
  fluencyScore       Float?
  vocabularyScore    Float?
  pronunciationScore Float?
  confidenceScore    Float?
  learningLevel      LearningLevel?
  isFlagged          Boolean        @default(false)
  flagReason         String?
  startedAt          DateTime       @default(now())
  completedAt        DateTime?

  // Every gating/reassessment/trend query filters userId then sorts or filters on completedAt
  @@index([userId, completedAt])
  @@map("baseline_assessments")
}

// Pronunciation Coach (US-95). One row per (userId, sentenceId) — a retry UPDATES this
// row (score replaced, never appended), per the story's "unlimited retries, score
// updates each time" requirement. sentenceId keys into data/pronunciation_sentences.json,
// not a DB foreign key (the sentence bank is static content, not user data).
model PronunciationAttempt {
  id                      String   @id @default(cuid())
  userId                  String
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sentenceId              String
  targetText              String
  transcript              String
  wordResults             Json                // [{word, target_index, status, confidence}]
  overallScore            Float
  accentProfileTag        String?             // US-90 Local Accent Calibration hook (stub — not applied yet)
  attemptCount            Int      @default(1)
  backgroundVoiceDetected Boolean  @default(false)
  disfluencyDetected      Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@unique([userId, sentenceId])
  @@index([userId])
  @@map("pronunciation_attempts")
}

// Accent Assessment (US-93). One row per passage-reading attempt, history kept (like
// BaselineAssessment) rather than overwritten, so a future re-calibration story has
// something to compare against. REJECTED_* rows carry no scores — never a false baseline.
model AccentAssessment {
  id                 String                 @id @default(cuid())
  userId             String
  user               User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  passageId          String
  status             AccentAssessmentStatus
  rejectionReason    String?
  transcript         String?
  pronunciationScore Float?
  stressScore        Float?
  rhythmScore        Float?
  intonationScore    Float?
  clarityScore       Float?
  weakPoints         Json                   @default("[]")
  createdAt          DateTime               @default(now())
  completedAt        DateTime?

  accentProfiles     AccentProfile[]

  @@index([userId, completedAt])
  @@map("accent_assessments")
}

// Accent Assessment & Improvement (US-89). Generated only from a COMPLETED
// AccentAssessment — services/accent_profile_service.py 404s rather than defaulting
// if none exists yet. History kept (multiple profiles over time), "latest" is canonical.
model AccentProfile {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceAssessmentId String
  sourceAssessment   AccentAssessment @relation(fields: [sourceAssessmentId], references: [id], onDelete: Cascade)
  pronunciationScore Float
  stressScore        Float
  rhythmScore        Float
  intonationScore    Float
  clarityScore       Float
  weakPoints         Json             // [{issue, detail}]
  exercises          Json             @default("[]")
  createdAt          DateTime         @default(now())

  @@index([userId, createdAt])
  @@map("accent_profiles")
}

model ReassessmentRequest {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestedAt   DateTime  @default(now())
  scheduledDate DateTime?
  completed     Boolean   @default(false)
  isEarlyRetake Boolean   @default(false)
  cycleCount    Int       @default(0)

  // Matches the early-retake-per-cycle count query: userId + cycleCount (+ isEarlyRetake)
  @@index([userId, cycleCount])
  @@map("reassessment_requests")
}

model PromptLog {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      PromptKind
  createdAt DateTime   @default(now())

  // Covers both promptlog.count(userId, kind) and find_first(userId, kind, order createdAt desc)
  @@index([userId, kind, createdAt])
  @@map("prompt_logs")
}

// Generic persistent key/value store backing the ported Interview Coach features.
// Those features carry rich nested session state as JSON blobs; rather
// than normalize each into its own table, they persist through lib/kv_store.py
// against this one table (namespace groups a feature's records; value is the blob).
model KvEntry {
  namespace String
  key       String
  userId    String?
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([namespace, key])
  @@index([namespace])
  @@index([userId])
  @@map("kv_entries")
}

// Accent Improvement Coach's periodic Accent Assessment (ACC-US-15's data source).
// monthIndex is 1-based and computed relative to the user's first completed
// accent assessment (1 = baseline), mirroring reassessment_service's cycle-count
// pattern for BaselineAssessment — one assessment allowed per 30-day month.
model AccentAssessment {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthIndex         Int
  pronunciationScore Float
  wordStressScore    Float
  intonationScore    Float
  clarityScore       Float
  completedAt        DateTime @default(now())
  createdAt          DateTime @default(now())

  // The tracker matrix always looks up userId + monthIndex (baseline = 1, current = 3).
  @@index([userId, monthIndex])
  @@map("accent_assessments")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Postgres doesn't auto-index relation scalars — refresh()/reset_password() revoke
  // all of a user's tokens by userId, which was a full table scan without this.
  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Matches forgot_password's invalidate-existing-tokens query: where userId + usedAt: None
  @@index([userId, usedAt])
  @@map("password_reset_tokens")
}

// Holds a signup until its emailed OTP is verified — password is already bcrypt-hashed
// here, never plaintext. Row is deleted on successful verify; a stale/abandoned row is
// just overwritten (upsert) if the same email signs up again.
model SignupOtp {
  email     String   @id
  name      String
  password  String
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("signup_otps")
}

# Same LiveKit project as Speeky/backend/.env — this worker joins rooms the backend
# minted a token for.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Where to POST transcribed turns back.
BACKEND_URL=http://localhost:8000

# Must match Speeky/backend/.env's INTERNAL_AGENT_SECRET exactly.
INTERNAL_AGENT_SECRET=
